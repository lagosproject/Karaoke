# SingChronized Environment Configuration Template
# Copy this file to .env and adjust variables as needed.
# Secrets and local configurations must NEVER be checked into git.

# -----------------------------------------------------------------------------
# 1. API Integrations (Optional but Recommended for Artwork/Metadata)
# -----------------------------------------------------------------------------

# Spotify API Client Credentials
# Create a developer account and register an application at https://developer.spotify.com
SPOTIFY_CLIENT_ID=<YOUR_SPOTIFY_CLIENT_ID_HERE>
SPOTIFY_CLIENT_SECRET=<YOUR_SPOTIFY_CLIENT_SECRET_HERE>

# Genius API Access Token
# Obtain a client access token by registering an app at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=<YOUR_GENIUS_ACCESS_TOKEN_HERE>

# -----------------------------------------------------------------------------
# 2. Local Storage Configuration (Optional Override)
# -----------------------------------------------------------------------------

# Override the directory where SingChronized stores imported songs, cache, and the database.
# Defaults to:
# - Linux: ~/.local/share/SingChronized
# - macOS: ~/Library/Application Support/SingChronized
# - Windows: %APPDATA%/SingChronized
# KARAOKE_DATA_DIR=/path/to/custom/data/directory
