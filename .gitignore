# ==========================================
# SingChronized Git Ignore Configuration
# ==========================================

# 1. Environment & Local Secrets (CRITICAL)
# ------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.p12
*.cer
*.crt
*.pfx

# 2. Python (Backend) Caches & Virtual Envs
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
.ipynb_checkpoints/

# 3. Node.js (Frontend) Dependencies & Builds
# --------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
frontend/dist/
frontend/build/

# 4. PyInstaller & Tauri Build Outputs
# -------------------------------------
/build/
/dist/
*.spec
!singchronized-backend.spec
frontend/src-tauri/target/
frontend/src-tauri/gen/
frontend/src-tauri/resources/
!frontend/src-tauri/resources/logo.svg

# 5. Application Library & Databases (Runtime)
# --------------------------------------------
backend/library/
backend/library.db
backend/library.db-journal
*.db
*.sqlite

# 6. IDEs & Editors
# ------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# 7. OS & System Caches
# ----------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
